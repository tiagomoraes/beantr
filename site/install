#!/usr/bin/env bash
# Beantr bootstrap installer. Downloads the latest pack and hands off to
# installers/install.sh, which owns all install logic.
#
#   # Show which agents are detected and how to install (installs nothing):
#   curl -fsSL https://beantr.tiagomoraes.cloud/install | bash
#
#   # Install for one agent (optionally with a ledger path):
#   curl -fsSL https://beantr.tiagomoraes.cloud/install | bash -s -- hermes ~/beantr
#   curl -fsSL https://beantr.tiagomoraes.cloud/install | bash -s -- claude-code
#
#   # Install for every detected agent on this machine, in one go:
#   curl -fsSL https://beantr.tiagomoraes.cloud/install | bash -s -- all
#
# Agent names: hermes, claude-code, opencode, openclaw, cowork, generic.
set -euo pipefail

PACK_URL="https://beantr.tiagomoraes.cloud/beantr-agent-pack-latest.tar.gz?v=2.0.0"
WORK_DIR="$(mktemp -d)"
trap 'rm -rf "$WORK_DIR"' EXIT

echo "Downloading Beantr..." >&2
curl -fsSL "$PACK_URL" | tar xz -C "$WORK_DIR"
cd "$WORK_DIR/beantr"

./installers/install.sh "$@"
